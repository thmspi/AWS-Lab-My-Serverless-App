{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAndImproveDinoScores",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:UpdateItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:__ACCOUNT_ID__:table/__TABLE_NAME__",
        "arn:aws:dynamodb:us-east-1:__ACCOUNT_ID__:table/__TABLE_NAME__/index/gameId-bestScore-index"
      ]
    },
    {
      "Sid": "CreateLambdaLogGroup",
      "Effect": "Allow",
      "Action": "logs:CreateLogGroup",
      "Resource": "arn:aws:logs:us-east-1:__ACCOUNT_ID__:*"
    },
    {
      "Sid": "WriteOnlyThisLambdaLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:__ACCOUNT_ID__:log-group:/aws/lambda/dino-score-api-*:log-stream:*"
    }
  ]
}

